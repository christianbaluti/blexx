{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm -w run build:shared && pnpm --filter @blex/api run build && mkdir -p public",
  "outputDirectory": "public",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    }
  }
}
