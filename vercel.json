{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build:shared && pnpm --filter @blex/api run build && mkdir -p public",
  "outputDirectory": "public",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.js": {
      "includeFiles": "db/postgres/**/*.sql",
      "maxDuration": 30
    }
  }
}
