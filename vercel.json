{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build:shared && pnpm --filter @blex/api run build && mkdir -p public",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/", "destination": "/api" },
    { "source": "/:path*", "destination": "/api/:path*" }
  ],
  "functions": {
    "api/**/*.mjs": {
      "maxDuration": 30
    }
  }
}
