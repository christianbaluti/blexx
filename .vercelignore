# Vercel deploys only the Fastify API. Keep the archive tiny by defaulting
# to ignored and explicitly allowing the workspace files needed by the API.
*

!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!tsconfig.json
!tsconfig.base.json
!vercel.json
!.env.example

!apps/
!apps/api/
!apps/api/package.json
!apps/api/tsconfig.json
!apps/api/src/
!apps/api/src/**

!packages/
!packages/shared/
!packages/shared/package.json
!packages/shared/tsconfig.json
!packages/shared/src/
!packages/shared/src/**

!scripts/
!scripts/**
