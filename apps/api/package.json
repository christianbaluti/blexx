{
  "name": "@blex/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "prebuild": "pnpm -w run build:shared",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:check": "tsx src/db-migrate.ts check",
    "db:create": "tsx src/db-migrate.ts create",
    "db:migrate": "tsx src/db-migrate.ts migrate",
    "db:seed": "tsx src/db-migrate.ts seed",
    "pretest": "pnpm -w run build:shared",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@blex/shared": "workspace:*",
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/sensible": "^6.0.3",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.2",
    "fastify": "^5.4.0",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.16.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
