{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "node": "22.13.1",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://blexx-api-ms2z.vercel.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "22.13.1",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://blexx-api-ms2z.vercel.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
